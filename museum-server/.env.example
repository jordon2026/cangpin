# ============================================================
# 博物馆管理系统 - 环境变量配置示例
# ============================================================
# 复制本文件为 .env（不要提交 .env 到 git！）
# 本地开发：在 IDE Run Configuration 中设置以下环境变量
# 生产部署：通过 Docker -e 参数或 Kubernetes Secret 注入
# ============================================================

# ---- 数据库 ----
# 【重要】生产环境请创建专用数据库账号，不要使用 root
DB_HOST=localhost
DB_PORT=3306
DB_NAME=museum_db
DB_USERNAME=museum_user
DB_PASSWORD=请替换为强密码

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- CORS 允许的前端来源（多个用英文逗号分隔，无空格）----
# 开发环境：
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# 生产环境示例：
# APP_CORS_ALLOWED_ORIGINS=https://museum.yourcompany.com

# ============================================================
# 生产环境注意事项：
# 1. 数据库账号需要只分配必要权限（SELECT/INSERT/UPDATE/DELETE），不使用 root
# 2. DB_PASSWORD 长度建议 ≥ 16 位，包含大小写字母、数字、特殊符号
# 3. Redis 生产环境务必设置密码（REDIS_PASSWORD）
# 4. CORS 只允许实际前端域名，不使用通配符 *
# ============================================================
