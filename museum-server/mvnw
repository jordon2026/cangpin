#!/bin/sh
# Maven Wrapper script
# Adapted from https://github.com/apache/maven-wrapper

set -e

# Determine project base directory
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(cd "$(dirname "$0")" && pwd)}"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

if [ -f "$MAVEN_WRAPPER_PROPERTIES" ]; then
    MAVEN_DIST_URL=$(grep "distributionUrl" "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2-)
fi

# Default Maven download URL
if [ -z "$MAVEN_DIST_URL" ]; then
    MAVEN_DIST_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.6/apache-maven-3.9.6-bin.zip"
fi

# Maven home
MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.6"

if [ ! -d "$MAVEN_HOME" ]; then
    echo "Downloading Maven..."
    mkdir -p "$MAVEN_HOME"
    TMP_FILE="$MAVEN_HOME/maven.zip"
    curl -fsSL "$MAVEN_DIST_URL" -o "$TMP_FILE"
    unzip -q "$TMP_FILE" -d "$MAVEN_HOME"
    mv "$MAVEN_HOME/apache-maven-3.9.6"/* "$MAVEN_HOME/"
    rm "$TMP_FILE"
fi

# Set JAVA_HOME if not set
if [ -z "$JAVA_HOME" ]; then
    JAVA_HOME="C:/Program Files/Amazon Corretto/jdk17.0.18_9"
    export JAVA_HOME
fi

exec "$MAVEN_HOME/bin/mvn" "$@"
